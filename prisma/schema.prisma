// Hawki Prompt Manager — Prisma Schema
// PostgreSQL via Prisma ORM

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum SchedulingSystem {
  CLINICORP
  CONTROLE_ODONTO
  SIMPLES_DENTAL
  GOOGLE_AGENDA
}

enum SchedulingMode {
  DIRECT   // Sofia agenda diretamente via API
  HANDOFF  // Sofia passa para humano
  LINK     // Sofia envia link de agendamento
}

enum ClientTone {
  FORMAL
  INFORMAL_MODERATE
  CASUAL
}

enum ClientStatus {
  ONBOARDING
  ACTIVE
  ARCHIVED
}

enum ModuleKey {
  IDENTITY
  INJECTION_PROTECTION
  TONE_AND_STYLE
  OPENING
  ATTENDANCE_FLOW
  QUALIFICATION
  OBJECTION_HANDLING
  FEW_SHOT_EXAMPLES
  AUDIO_AND_HANDOFF
  ABSOLUTE_RULES
}

enum GeneratedBy {
  AI
  MANUAL
}

enum TicketPriority {
  CRITICAL
  NORMAL
  IMPROVEMENT
}

enum TicketStatus {
  OPEN
  SUGGESTED
  APPROVED
  APPLIED
  REJECTED
}

enum RegressionRunStatus {
  PENDING
  PASSED
  FAILED
}

enum PromptVersionStatus {
  PENDING_REVIEW  // aguardando aprovação humana após pipeline automático
  ACTIVE          // versão operacional atual
  ARCHIVED        // versão anterior
}

enum ConvOutcome {
  SCHEDULED
  NOT_SCHEDULED
  LOST
}

enum ServiceCategory {
  IMPLANTES
  ORTODONTIA
  ESTETICA
  CLINICO_GERAL
  PERIODONTIA
  ENDODONTIA
  PEDIATRIA
  PROTESE
  CIRURGIA
  OUTROS
}

enum InteractionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum KnowledgeStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OutcomeSource {
  MANUAL              // admin digitou no painel
  CRM_DENTAL_OFFICE
  CRM_CLINICORP
  CRM_EAI_DOCTOR
  CRM_OTHER
  API_WEBHOOK         // Sofia ou cliente posta direto via webhook
}

// ─────────────────────────────────────────────
// Client — dados do cliente (clínica)
// ─────────────────────────────────────────────

model Client {
  id                String           @id @default(cuid())
  name              String           // nome do contato / responsável
  clinicName        String           // nome da clínica (como aparece nas mensagens)
  assistantName     String           @default("Sofia")
  email             String?          // email do responsável
  city              String?
  state             String?          // estado (ex: SP, PR)
  zipCode           String?          // CEP
  neighborhood      String?
  address           String?
  reference         String?          // ponto de referência
  phone             String?
  instagram         String?
  website           String?
  attendantName     String?          // responsável humano no handoff
  emojiUsage        String?          // regra de uso de emojis (ex: moderado, 1-2 por mensagem)
  treatmentPronoun  String?          // pronome de tratamento (Você / Tu)
  schedulingSystem  SchedulingSystem?
  schedulingMode    SchedulingMode?
  tone              ClientTone?
  targetAudience    String?          // texto livre: público-alvo
  ageRange          String?          // ex: "40+", "18-35"
  restrictions          String?          // o que Sofia nunca pode fazer/dizer
  mandatoryPhrases      String?          // informações que Sofia SEMPRE deve mencionar
  consultationInfo      String?          // como funciona a primeira consulta / avaliação
  schedulingRequirements String?         // dados obrigatórios para agendar
  paymentInfo           String?          // formas de pagamento
  urgencyHandling       String?          // atende urgência odontológica?
  urgencyProcedure      String?          // como Sofia deve proceder em urgências
  specialists       String?          // dentistas e especialidades (texto livre)
  certifications    String?          // certificações, prêmios ou diferenciais dos profissionais
  technologies      String?          // equipamentos e tecnologias confirmadas
  differentials     String?          // diferenciais reais da clínica
  businessHours     String?          // horários de atendimento
  procedureType     String?          // especialidade majoritária
  clinicPositioning String?          // posicionamento (ex: Popular, Intermediária, Premium)
  serviceCategories ServiceCategory[]               // especialidades principais (usadas para injeção de conhecimento)
  minConversationsPerVersion Int     @default(10) // mínimo de conversas por versão
  status            ClientStatus     @default(ONBOARDING)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  promptVersions      PromptVersion[]
  tickets             CorrectionTicket[]
  onboardingUploads   OnboardingUpload[]
  apiUsageLogs        ApiUsageLog[]
  regressionCases     RegressionCase[]
  calibrations        Calibration[]
  leadOriginTags      LeadOriginTag[]
  conversationSamples ConversationSample[]
  knowledgeArticles   ClientKnowledgeArticle[]
}

// ─────────────────────────────────────────────
// PromptVersion — versão completa do prompt
// ─────────────────────────────────────────────

model PromptVersion {
  id              String      @id @default(cuid())
  clientId        String
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  version         Int         // sequencial: 1, 2, 3...
  systemPrompt    String      @db.Text
  ragDocument     String?     @db.Text
  narrativeManual String?     @db.Text
  isActive           Boolean              @default(false)
  status             PromptVersionStatus  @default(ACTIVE)
  problemDescription String?              @db.Text  // problema descrito pelo usuário no import
  generatedBy        GeneratedBy          @default(AI)
  changesSummary     String?              // motivo da mudança (input do usuário)
  savedBy            String?              // Clerk userId de quem salvou
  createdAt          DateTime             @default(now())

  modules             PromptModule[]
  tickets             CorrectionTicket[]
  conversationSamples ConversationSample[]

  @@unique([clientId, version])
}

// ─────────────────────────────────────────────
// PromptModule — módulo individual de uma versão
// ─────────────────────────────────────────────

model PromptModule {
  id              String        @id @default(cuid())
  promptVersionId String
  promptVersion   PromptVersion @relation(fields: [promptVersionId], references: [id], onDelete: Cascade)
  moduleKey       ModuleKey
  content         String        @db.Text
  updatedAt       DateTime      @updatedAt

  @@unique([promptVersionId, moduleKey])
}

// ─────────────────────────────────────────────
// CorrectionTicket — ticket de correção
// ─────────────────────────────────────────────

model CorrectionTicket {
  id                     String         @id @default(cuid())
  clientId               String
  client                 Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  promptVersionId        String
  promptVersion          PromptVersion  @relation(fields: [promptVersionId], references: [id])
  description            String         @db.Text
  conversationTranscript String?        @db.Text
  affectedModule         ModuleKey?
  priority               TicketPriority @default(NORMAL)
  status                 TicketStatus   @default(OPEN)
  aiSuggestion           String?        @db.Text
  finalCorrection        String?        @db.Text
  resolvedInVersionId    String?
  createdAt              DateTime       @default(now())
  resolvedAt             DateTime?
}

// ─────────────────────────────────────────────
// RegressionCase — caso de teste de regressão
// ─────────────────────────────────────────────

model RegressionCase {
  id               String          @id @default(cuid())
  clientId         String
  client           Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name             String
  input            String          @db.Text  // mensagem de entrada enviada para a Sofia
  expectedResponse String?         @db.Text  // como a Sofia deveria responder idealmente (opcional)
  criteria         String[]                  // lista de critérios esperados
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  runs      RegressionRun[]
}

// ─────────────────────────────────────────────
// RegressionRun — execução de um caso de teste
// ─────────────────────────────────────────────

model RegressionRun {
  id       String              @id @default(cuid())
  caseId   String
  case     RegressionCase      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  response String              @db.Text  // resposta gerada pelo Claude
  results  Json                // { criterion: string, passed: boolean | null }[]
  status   RegressionRunStatus @default(PENDING)
  runAt    DateTime            @default(now())
}

// ─────────────────────────────────────────────
// Calibration — comparação Sofia vs humano
// ─────────────────────────────────────────────

model Calibration {
  id                String   @id @default(cuid())
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  humanConversation String   @db.Text
  sofiaConversation String   @db.Text
  gaps              Json     // { axis, description, promptSuggestion }[]
  appliedToPrompt   Boolean  @default(false)
  createdAt         DateTime @default(now())
}

// ─────────────────────────────────────────────
// LeadOriginTag — personalização por origem do lead
// ─────────────────────────────────────────────

model LeadOriginTag {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag       String               // "Anúncio Implante"
  opening   String   @db.Text   // abertura personalizada
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false) // true = tag padrão (sem origem específica)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// ConversationSample — banco de conversas reais
// ─────────────────────────────────────────────

model ConversationSample {
  id              String        @id @default(cuid())
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  promptVersionId String
  promptVersion   PromptVersion @relation(fields: [promptVersionId], references: [id])
  content         String        @db.Text  // texto bruto da conversa
  outcome         ConvOutcome?            // agendou / não agendou / perdeu
  notes           String?                 // observação livre
  source          String?                 // "whatsapp", "interno" etc
  createdAt       DateTime      @default(now())
}

// ─────────────────────────────────────────────
// ApiUsageLog — rastreamento de custo por operação
// ─────────────────────────────────────────────

model ApiUsageLog {
  id           String   @id @default(cuid())
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  operation    String
  model        String
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────
// KnowledgeDocument — base de conhecimento da Hawki
// ─────────────────────────────────────────────

model KnowledgeDocument {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  category  String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// PromptTemplate — templates universais de prompt
// ─────────────────────────────────────────────

model PromptTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  content     String   @db.Text
  version     String   @default("v1.0")
  isActive    Boolean  @default(true)
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// OnboardingUpload — CSV original do cliente
// ─────────────────────────────────────────────

model OnboardingUpload {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  parsedData  Json
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// SuccessfulInteraction — conversas aprovadas, cross-tenant
// Sem clientId: dados anonimizados que alimentam a inteligência Hawki.
// ─────────────────────────────────────────────

model SuccessfulInteraction {
  id             String            @id @default(cuid())
  // SEM clientId — dados anônimos e reutilizáveis entre clientes
  category       ServiceCategory
  transcript     String            @db.Text   // texto anonimizado (sem clínica/nome)
  outcome        ConvOutcome                  // SCHEDULED | NOT_SCHEDULED | LOST (sinal raso da conversa)
  scoreQuality   Float?                       // 0–1: qualidade geral avaliada por LLM
  scoreTone      Float?                       // 0–1: adequação do tom
  scoreObjection Float?                       // 0–1: handling de objeções
  status         InteractionStatus @default(PENDING_REVIEW)
  reviewedAt     DateTime?
  reviewNote     String?           @db.Text
  uploadedAt     DateTime          @default(now())

  // Outcome real (ground truth do mundo): preenchido manualmente ou via CRM/webhook.
  // Relação 1:1 — uma interação tem no máximo um outcome consolidado.
  conversationOutcome ConversationOutcome?

  @@index([category, status])
}

// ─────────────────────────────────────────────
// ConversationOutcome — desfecho real (ground truth) de uma interação
// Modelo de evento: aceita updates incrementais ao longo do tempo
// (scheduledAt → appointmentDate → showedUp → treatmentClosed → revenueCents).
// Origem: MANUAL (curador digita) ou CRM/webhook quando integração estiver ativa.
// ─────────────────────────────────────────────

model ConversationOutcome {
  id              String                @id @default(cuid())
  interactionId   String                @unique
  interaction     SuccessfulInteraction @relation(fields: [interactionId], references: [id], onDelete: Cascade)

  // Funil de conversão — preenchidos progressivamente
  scheduledAt     DateTime?      // quando o agendamento foi confirmado
  appointmentDate DateTime?      // data marcada da consulta
  showedUp        Boolean?       // paciente apareceu no horário?
  treatmentClosed Boolean?       // fechou tratamento depois da primeira consulta?
  revenueCents    Int?           // receita real em centavos (R$ 4500,00 → 450000)

  source          OutcomeSource
  notes           String?        @db.Text

  // Auditoria
  enteredAt       DateTime       @default(now())
  enteredBy       String?        // Clerk userId
  updatedAt       DateTime       @updatedAt
  updatedBy       String?        // Clerk userId do último update

  @@index([source])
  @@index([showedUp])
  @@index([treatmentClosed])
}

// ─────────────────────────────────────────────
// AnonymizationCache — cache de redactions feitas via NER
// Chave: hash SHA-256 do texto (pós-regex). Evita pagar Haiku por reprocessamento.
// ─────────────────────────────────────────────

model AnonymizationCache {
  contentHash String   @id              // SHA-256 hex do texto de entrada
  anonymized  String   @db.Text         // texto final pós-NER
  level       String                    // "regex" | "ner" | "strict"
  redactions  Json?                     // metadata: { type, values: string[] }[]
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// KnowledgeBatch — lote gerado por uma destilação
// Agrupa 3-5 insights extraídos juntos. Ativação é atômica:
// promover um batch arquiva todos os outros ACTIVE da mesma categoria.
// ─────────────────────────────────────────────

model KnowledgeBatch {
  id           String          @id @default(cuid())
  category     ServiceCategory
  status       KnowledgeStatus @default(DRAFT)
  sourceCount  Int             @default(0)  // nº de interações que originaram o batch
  notes        String?         @db.Text     // metadata opcional (ex: "destilação manual após calibração X")
  createdAt    DateTime        @default(now())
  activatedAt  DateTime?
  archivedAt   DateTime?

  insights     SpecialtyKnowledge[]

  @@index([category, status])
}

// ─────────────────────────────────────────────
// SpecialtyKnowledge — insights destilados por categoria
// Sem clientId: cada insight é injetado em qualquer clínica da mesma categoria.
// ─────────────────────────────────────────────

model SpecialtyKnowledge {
  id              String          @id @default(cuid())
  // SEM clientId — conhecimento compartilhado cross-tenant
  category        ServiceCategory
  title           String
  insight         String          @db.Text   // insight destilado para o prompt
  examplePhrase   String?         @db.Text   // objeção ou frase típica do paciente
  exampleResponse String?         @db.Text   // resposta modelo da Sofia
  status          KnowledgeStatus @default(DRAFT)
  sourceCount     Int             @default(0) // nº de interações que originaram este insight
  batchId         String?                     // null = insight manual; preenchido = veio de destilação
  batch           KnowledgeBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([category, status])
  @@index([batchId])
}

// ─────────────────────────────────────────────
// ClientKnowledgeArticle — KB por cliente
// ─────────────────────────────────────────────

model ClientKnowledgeArticle {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  topic     String   // localizacao | primeira_consulta | procedimentos | precos_pagamento | convenios | diferenciais | urgencias | pos_procedimento
  title     String
  content   String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, topic])
}
