# ─────────────────────────────────────────────
# Hawki Prompt Manager — Environment Variables
# ─────────────────────────────────────────────
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local — ele já está no .gitignore.

# Banco de dados (PostgreSQL via Supabase)
# Encontre em: Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres:<senha>@db.<projeto>.supabase.co:5432/postgres"

# Anthropic API
# Encontre em: console.anthropic.com → API Keys
# ATENÇÃO: use HAWKI_ANTHROPIC_API_KEY (não ANTHROPIC_API_KEY) — o nome padrão
# pode colidir com variáveis de ambiente injetadas por outras ferramentas (ex: Claude Desktop).
HAWKI_ANTHROPIC_API_KEY="sk-ant-api03-..."

# Clerk (Autenticação)
# Encontre em: dashboard.clerk.com → seu app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Supabase (Storage para uploads)
# Encontre em: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<projeto>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."

# ─────────────────────────────────────────────
# Inteligência Hawki
# ─────────────────────────────────────────────

# Emails autorizados a curar conversas (separados por vírgula).
# Em desenvolvimento (NODE_ENV=development) o bypass é ativo automaticamente.
INTELLIGENCE_ADMIN_EMAILS="contato@hawki.com.br"

# Nível de anonymização aplicado antes de persistir transcrições no corpus cross-tenant:
#   regex   — apenas regex (rápido, gratuito, vaza nomes próprios)
#   ner     — regex + Haiku NER para nomes/clínicas/dentistas/endereços/valores (default, ~$0.001/conversa)
#   strict  — ner + obriga revisão humana antes de auto-aprovar (recomendado em produção)
ANONYMIZATION_LEVEL="ner"

# DIRECT_URL (opcional): URL postgres em session mode (port 5432) para migrações.
# Se ausente, prisma.config.ts auto-deriva substituindo :6543 por :5432 em DATABASE_URL.
# DIRECT_URL="postgresql://postgres:<senha>@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"
